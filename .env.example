# --- Telegram Stars ---
STARS_COINS_RATE=2

# --- TON горячий кошелёк (авто-вывод USDT) ---
# 24 слова через пробел — НИКОГДА не коммить реальные ключи!
TON_HOT_WALLET_MNEMONIC=word1 word2 word3 ... word24
WITHDRAW_AUTO_ENABLED=false
WITHDRAW_MAX_AUTO_USDT=500
